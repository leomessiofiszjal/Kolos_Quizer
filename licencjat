        // ==========================================
        // LOGIKA WIDOKU I STEROWANIE
        // ==========================================
        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
        }

        // ==========================================
        // LOGIKA FISZEK
        // ==========================================
        let quizData = [...rawQuizData];
        let currentFlashcardIndex = 0;
        let isFlipped = false;

        const flashcard = document.getElementById('flashcard');
        const cardFront = document.getElementById('card-front');
        const cardBack = document.getElementById('card-back');
        const counter = document.getElementById('counter');

        function loadCard() {
            if(quizData.length === 0) return;
            cardFront.innerHTML = quizData[currentFlashcardIndex].question;
            cardBack.innerHTML = quizData[currentFlashcardIndex].flashcardAnswer;
            counter.innerText = `${currentFlashcardIndex + 1} / ${quizData.length}`;
            
            if (isFlipped) {
                flashcard.classList.remove('is-flipped');
                isFlipped = false;
            }
            setTimeout(() => { cardFront.scrollTop = 0; cardBack.scrollTop = 0; }, 300);
        }

        function flipCard() { flashcard.classList.toggle('is-flipped'); isFlipped = !isFlipped; }

        function nextCard() {
            if (currentFlashcardIndex < quizData.length - 1) currentFlashcardIndex++;
            else currentFlashcardIndex = 0;
            if (isFlipped) { flipCard(); setTimeout(loadCard, 300); } else { loadCard(); }
        }

        function prevCard() {
            if (currentFlashcardIndex > 0) currentFlashcardIndex--;
            else currentFlashcardIndex = quizData.length - 1;
            if (isFlipped) { flipCard(); setTimeout(loadCard, 300); } else { loadCard(); }
        }

        function shuffleDeck() { shuffleArray(quizData); currentFlashcardIndex = 0; loadCard(); }
        function resetDeck() { quizData = [...rawQuizData]; currentFlashcardIndex = 0; loadCard(); }

        // ==========================================
        // OBSŁUGA KLAWIATURY
        // ==========================================
        document.addEventListener('keydown', (e) => {
            if (e.code === 'Space') { e.preventDefault(); flipCard(); }
            else if (e.code === 'ArrowRight') { nextCard(); }
            else if (e.code === 'ArrowLeft') { prevCard(); }
        });

        // Inicjalizacja pierwszej karty
        loadCard();
    </script>
